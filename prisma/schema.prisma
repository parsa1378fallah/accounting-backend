enum CheckStatus {
  ISSUED
  RECEIVED
  IN_BANK
  CLEARED
  RETURNED
  BOUNCED
  CANCELLED
}

model CheckBook {
  id             String   @id @default(cuid())
  organizationId String
  bankAccountId  String
  title          String
  fromSerial     String
  toSerial       String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
  checks      Check[]
}

model Check {
  id             String      @id @default(cuid())
  organizationId String
  serialNumber   String
  checkBookId    String?
  partyId        String?
  bankAccountId  String?
  amount         Decimal     @db.Decimal(20, 4)
  issueDate      DateTime?
  dueDate        DateTime
  status         CheckStatus
  description    String?
  journalEntryId String?

  checkBook    CheckBook?    @relation(fields: [checkBookId], references: [id])
  party        Party?        @relation(fields: [partyId], references: [id])
  bankAccount  BankAccount?  @relation(fields: [bankAccountId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // FIX: Relation اضافه شد
  payments Payment[]

  @@index([organizationId, status])
  @@index([dueDate])
}

enum PaymentType {
  INBOUND
  OUTBOUND
}

enum PaymentMethod {
  CASH
  BANK
  CHECK
}

enum PaymentStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

// FIX: cashTransactionId, bankTransactionId, checkId حالا Relation واقعی دارند
model Payment {
  id                String        @id @default(cuid())
  organizationId    String
  partyId           String?
  type              PaymentType
  method            PaymentMethod
  status            PaymentStatus @default(DRAFT)
  amount            Decimal       @db.Decimal(20, 4)
  cashTransactionId String?
  bankTransactionId String?
  checkId           String?
  referenceType     String?
  referenceId       String?
  description       String?
  paymentDate       DateTime
  journalEntryId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  party           Party?           @relation(fields: [partyId], references: [id])
  journalEntry    JournalEntry?    @relation(fields: [journalEntryId], references: [id])
  // FIX: Relation های واقعی اضافه شدند
  cashTransaction CashTransaction? @relation(fields: [cashTransactionId], references: [id])
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id])
  check           Check?           @relation(fields: [checkId], references: [id])
  invoicePayments InvoicePayment[]
  BankAccount     BankAccount[]

  @@index([organizationId, type, status])
  @@index([partyId])
}

enum ReconciliationStatus {
  DRAFT
  MATCHED
  CLOSED
}

model BankReconciliation {
  id             String               @id @default(cuid())
  organizationId String
  bankAccountId  String
  statementDate  DateTime
  status         ReconciliationStatus @default(DRAFT)
  openingBalance Decimal              @db.Decimal(20, 4)
  closingBalance Decimal              @db.Decimal(20, 4)
  difference     Decimal              @db.Decimal(20, 4)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  bankAccount BankAccount              @relation(fields: [bankAccountId], references: [id])
  items       BankReconciliationItem[]

  @@unique([bankAccountId, statementDate])
}

enum ReconciliationItemType {
  BANK_TRANSACTION
  JOURNAL_ENTRY
}

model BankReconciliationItem {
  id               String                 @id @default(cuid())
  reconciliationId String
  type             ReconciliationItemType
  referenceId      String
  amount           Decimal                @db.Decimal(20, 4)
  isMatched        Boolean                @default(false)
  matchedAt        DateTime?

  reconciliation BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@index([reconciliationId, isMatched])
}

model InvoicePayment {
  id                String   @id @default(cuid())
  organizationId    String
  paymentId         String
  salesInvoiceId    String?
  purchaseInvoiceId String?
  amount            Decimal  @db.Decimal(20, 4)
  createdAt         DateTime @default(now())

  payment         Payment          @relation(fields: [paymentId], references: [id])
  salesInvoice    SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id])
  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])

  @@index([paymentId])
  @@index([salesInvoiceId])
  @@index([purchaseInvoiceId])
}

