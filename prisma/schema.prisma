enum SalesQuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model SalesQuotation {
  id              String               @id @default(cuid())
  organizationId  String
  quotationNumber String
  customerId      String
  quotationDate   DateTime
  validUntil      DateTime?
  status          SalesQuotationStatus
  taxGroupId      String?
  subtotal        Decimal              @db.Decimal(20, 4)
  discountAmount  Decimal              @default(0) @db.Decimal(20, 4)
  taxAmount       Decimal              @default(0) @db.Decimal(20, 4)
  totalAmount     Decimal              @db.Decimal(20, 4)
  notes           String?

  customer Party                @relation(fields: [customerId], references: [id])
  items    SalesQuotationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, quotationNumber])
}

model SalesQuotationItem {
  id             String  @id @default(cuid())
  quotationId    String
  productId      String
  taxRateId      String?
  quantity       Decimal @db.Decimal(20, 4)
  unitPrice      Decimal @db.Decimal(20, 4)
  discountAmount Decimal @default(0) @db.Decimal(20, 4)
  taxAmount      Decimal @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal @db.Decimal(20, 4)
  description    String?

  quotation SalesQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_DELIVERED
  DELIVERED
  CANCELLED
}

model SalesOrder {
  id             String           @id @default(cuid())
  organizationId String
  orderNumber    String
  customerId     String
  orderDate      DateTime
  deliveryDate   DateTime?
  status         SalesOrderStatus
  taxGroupId     String?
  subtotal       Decimal          @db.Decimal(20, 4)
  discountAmount Decimal          @default(0) @db.Decimal(20, 4)
  taxAmount      Decimal          @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal          @db.Decimal(20, 4)
  notes          String?

  customer      Party            @relation(fields: [customerId], references: [id])
  items         SalesOrderItem[]
  salesInvoices SalesInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, orderNumber])
}

model SalesOrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  taxRateId      String?
  quantity       Decimal @db.Decimal(20, 4)
  deliveredQty   Decimal @default(0) @db.Decimal(20, 4)
  unitPrice      Decimal @db.Decimal(20, 4)
  discountAmount Decimal @default(0) @db.Decimal(20, 4)
  taxAmount      Decimal @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal @db.Decimal(20, 4)
  description    String?

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

enum SalesInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model SalesInvoice {
  id             String             @id @default(cuid())
  organizationId String
  invoiceNumber  String
  customerId     String
  orderId        String?
  invoiceDate    DateTime
  dueDate        DateTime?
  status         SalesInvoiceStatus
  taxGroupId     String?
  subtotal       Decimal            @db.Decimal(20, 4)
  discountAmount Decimal            @default(0) @db.Decimal(20, 4)
  taxAmount      Decimal            @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal            @db.Decimal(20, 4)
  paidAmount     Decimal            @default(0) @db.Decimal(20, 4)
  notes          String?
  journalEntryId String?

  customer     Party         @relation(fields: [customerId], references: [id])
  order        SalesOrder?   @relation(fields: [orderId], references: [id])
  journalEntry JournalEntry? @relation(fields: [journalEntryId], references: [id])

  items           SalesInvoiceItem[]
  salesReturns    SalesReturn[]
  invoicePayments InvoicePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, status])
  @@index([dueDate])
}

model SalesInvoiceItem {
  id             String  @id @default(cuid())
  invoiceId      String
  productId      String
  taxRateId      String?
  quantity       Decimal @db.Decimal(20, 4)
  unitPrice      Decimal @db.Decimal(20, 4)
  discountAmount Decimal @default(0) @db.Decimal(20, 4)
  taxAmount      Decimal @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal @db.Decimal(20, 4)
  description    String?

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
}

model SalesReturn {
  id             String   @id @default(cuid())
  organizationId String
  invoiceId      String
  returnNumber   String
  returnDate     DateTime
  reason         String?
  subtotal       Decimal  @db.Decimal(20, 4)
  taxAmount      Decimal  @default(0) @db.Decimal(20, 4)
  totalAmount    Decimal  @db.Decimal(20, 4)
  journalEntryId String?

  invoice SalesInvoice      @relation(fields: [invoiceId], references: [id])
  items   SalesReturnItem[]

  createdAt DateTime @default(now())

  @@unique([organizationId, returnNumber])
}

model SalesReturnItem {
  id          String  @id @default(cuid())
  returnId    String
  productId   String
  quantity    Decimal @db.Decimal(20, 4)
  unitPrice   Decimal @db.Decimal(20, 4)
  taxAmount   Decimal @default(0) @db.Decimal(20, 4)
  totalAmount Decimal @db.Decimal(20, 4)

  return  SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id])
}

