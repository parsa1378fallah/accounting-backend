generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ================================================================
// CORE — Organization, Branch, Fiscal Year, Users, RBAC
// ================================================================

model Organization {
  id         String  @id @default(cuid())
  name       String
  code       String  @unique
  legalName  String?
  nationalId String?
  taxNumber  String?
  phone      String?
  email      String?
  address    String? @db.Text
  isActive   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branches            Branch[]
  fiscalYears         FiscalYear[]
  users               User[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  numberSequences     NumberSequence[]
  parties             Party[]
  cashBoxes           CashBox[]
  costCenters         CostCenter[]
  projects            Project[]
  warehouses          Warehouse[]
  products            Product[]
  productCategories   ProductCategory[]
  bankAccounts        BankAccount[]
  transfers           Transfer[]
  systemAccounts      SystemAccount[]
  journalTemplates    JournalTemplate[]
  payments            Payment[]
  userRoles           UserRole[]
  taxRates            TaxRate[]
  taxGroups           TaxGroup[]
  employees           Employee[]
  payrollRuns         PayrollRun[]
  boms                BillOfMaterials[]
  productionOrders    ProductionOrder[]
  reportSnapshots     ReportSnapshot[]
  attachments         Attachment[]
  workflowDefinitions WorkflowDefinition[]
  workflowInstances   WorkflowInstance[]
  stockTransfers      StockTransfer[]
  purchaseRequests    PurchaseRequest[]
  recurringJournals   RecurringJournal[]
  contracts           Contract[]
  assets              Asset[]
  assetCategories     AssetCategory[]
  budgets             Budget[]

  Role Role[]

  FxGainLossEntry FxGainLossEntry[]
}

model Branch {
  id             String  @id @default(cuid())
  organizationId String
  code           String
  name           String
  phone          String?
  address        String? @db.Text
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id])
  journalEntries JournalEntry[]
  warehouses     Warehouse[]

  @@unique([organizationId, code])
}

model FiscalYear {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  startAt        DateTime
  endAt          DateTime
  isClosed       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id])
  periods        FiscalPeriod[]
  journalEntries JournalEntry[]
  closing        FiscalYearClosing?
  budgets        Budget[]
}

model FiscalPeriod {
  id           String   @id @default(cuid())
  fiscalYearId String
  name         String?
  startDate    DateTime
  endDate      DateTime
  isClosed     Boolean  @default(false)

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])

  @@index([fiscalYearId])
}

// ----------------------------------------------------------------
// RBAC
// ----------------------------------------------------------------

model Role {
  id String @id @default(cuid())

  organizationId String?

  name String

  code String

  description String?

  isSystem Boolean @default(false)

  isActive Boolean @default(true)

  organization Organization? @relation(fields: [organizationId], references: [id])

  rolePermissions RolePermission[]

  userRoles UserRole[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  module      String
  description String?

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organizationId String?

  Organization       Organization?       @relation(fields: [organizationId], references: [id])
  journalApprovals   JournalApproval[]
  fiscalYearClosings FiscalYearClosing[]
  notifications      Notification[]
  sessions           UserSession[]
  userRoles          UserRole[]
  auditLogs          AuditLog[]
  // NEW
  workflowActions    WorkflowAction[]
  reportSnapshots    ReportSnapshot[]    @relation("ReportGeneratedBy")
}

model UserRole {
  userId         String
  roleId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@id([userId, roleId, organizationId])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  ip        String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model NumberSequence {
  id             String @id @default(cuid())
  organizationId String
  entity         String
  prefix         String
  currentNumber  Int
  padding        Int    @default(6)

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, entity])
}

// ================================================================
// ACCOUNTING ENGINE
// ================================================================

model Currency {
  id String @id @default(cuid())

  code   String  @unique
  name   String
  symbol String?

  isBase        Boolean @default(false)
  isActive      Boolean @default(true)
  decimalPlaces Int     @default(2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  exchangeRates     ExchangeRate[]
  journalEntryLines JournalEntryLine[]
  priceLists        PriceList[]

  fxSourceEntries FxGainLossEntry[] @relation("FxSourceCurrency")

  fxBaseEntries FxGainLossEntry[] @relation("FxBaseCurrency")
}

enum ExchangeRateStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model ExchangeRate {
  id String @id @default(cuid())

  organizationId String

  currencyId String
  rate       Decimal @db.Decimal(18, 6)

  effectiveDate DateTime

  source String?
  status ExchangeRateStatus @default(ACTIVE)

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdBy String?
  updatedBy String?

  version Int @default(1)

  currency Currency @relation(fields: [currencyId], references: [id])

  @@unique([currencyId, effectiveDate])
  @@index([currencyId, effectiveDate])
  @@index([currencyId, organizationId])
}

enum FxEntryType {
  REALIZED
  UNREALIZED
}

enum FxDirection {
  GAIN
  LOSS
}

model FxGainLossEntry {
  id String @id @default(cuid())

  organizationId String

  journalEntryId String

  currencyId String

  baseCurrencyId String

  entryType FxEntryType

  direction FxDirection

  amount Decimal @db.Decimal(20, 4)

  exchangeRate Decimal @db.Decimal(20, 8)

  sourceAmount Decimal @db.Decimal(20, 4)

  referenceType String?
  referenceId   String?

  description String?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])

  currency Currency @relation("FxSourceCurrency", fields: [currencyId], references: [id])

  baseCurrency Currency @relation("FxBaseCurrency", fields: [baseCurrencyId], references: [id])

  @@index([organizationId])
  @@index([journalEntryId])
  @@index([currencyId])
  @@index([baseCurrencyId])
  @@index([entryType])
  @@index([direction])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

enum AccountNature {
  DEBIT
  CREDIT
}

enum AccountLevel {
  GROUP
  GENERAL
  SUBSIDIARY
  DETAIL
}

model AccountGroup {
  id         String            @id @default(cuid())
  code       String            @unique
  name       String
  nature     AccountNature
  categories AccountCategory[]
}

model AccountCategory {
  id             String @id @default(cuid())
  accountGroupId String
  code           String
  name           String

  accountGroup AccountGroup @relation(fields: [accountGroupId], references: [id])
  accounts     Account[]

  @@unique([accountGroupId, code])
}

model Account {
  id                String       @id @default(cuid())
  organizationId    String
  accountCategoryId String
  parentId          String?
  code              String
  name              String
  level             AccountLevel
  isLeaf            Boolean
  isActive          Boolean      @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization    Organization          @relation(fields: [organizationId], references: [id])
  accountCategory AccountCategory       @relation(fields: [accountCategoryId], references: [id])
  parent          Account?              @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]             @relation("AccountHierarchy")
  journalLines    JournalEntryLine[]
  cashBoxes       CashBox[]
  bankAccounts    BankAccount[]
  systemAccounts  SystemAccount[]
  templateLines   JournalTemplateLine[]

  @@unique([organizationId, code])
  @@index([parentId])
}

model CostCenter {
  id             String    @id @default(cuid())
  organizationId String
  code           String
  name           String
  parentId       String?
  isActive       Boolean   @default(true)
  // FIX: اضافه شد
  deletedAt      DateTime?

  organization          Organization       @relation(fields: [organizationId], references: [id])
  parent                CostCenter?        @relation("CostCenterTree", fields: [parentId], references: [id])
  children              CostCenter[]       @relation("CostCenterTree")
  journalLines          JournalEntryLine[]
  // FIX: جایگزین Allocation قدیمی
  allocationCostCenters Allocation[]

  @@unique([organizationId, code])
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  code           String
  name           String
  status         ProjectStatus
  startDate      DateTime?
  endDate        DateTime?
  budget         Decimal?      @db.Decimal(20, 4)
  // FIX: اضافه شد
  deletedAt      DateTime?

  organization       Organization       @relation(fields: [organizationId], references: [id])
  journalLines       JournalEntryLine[]
  // FIX: جایگزین Allocation قدیمی
  allocationProjects Allocation[]

  @@unique([organizationId, code])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum JournalEntryStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  CANCELLED
}

model JournalEntry {
  id             String             @id @default(cuid())
  organizationId String
  fiscalYearId   String
  branchId       String
  entryNumber    String
  description    String?            @db.Text
  status         JournalEntryStatus @default(DRAFT)
  referenceType  String?
  referenceId    String?
  totalDebit     Decimal            @db.Decimal(20, 4)
  totalCredit    Decimal            @db.Decimal(20, 4)

  // Posting
  postedAt   DateTime?
  postedById String?

  // Reversal
  isReversal   Boolean   @default(false)
  reversalOfId String?
  reversalDate DateTime?

  // Lock
  isLocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  fiscalYear   FiscalYear   @relation(fields: [fiscalYearId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])

  // Self Relation
  reversalOf JournalEntry? @relation("JournalReversal", fields: [reversalOfId], references: [id])

  reversals JournalEntry[] @relation("JournalReversal")

  lines             JournalEntryLine[]
  attachments       JournalAttachment[]
  approvals         JournalApproval[]
  purchaseInvoices  PurchaseInvoice[]
  cashTransactions  CashTransaction[]
  bankTransactions  BankTransaction[]
  checks            Check[]
  salesInvoices     SalesInvoice[]
  transfers         Transfer[]
  payments          Payment[]
  fxEntries         FxGainLossEntry[]
  RecurringJournal  RecurringJournal[]  @relation("RecurringSource")
  StockTransfer     StockTransfer[]
  AssetDepreciation AssetDepreciation[]

  @@unique([organizationId, entryNumber])
  @@index([organizationId, status])
  @@index([fiscalYearId])
  @@index([reversalOfId])
}

model JournalEntryLine {
  id             String  @id @default(cuid())
  journalEntryId String
  accountId      String
  costCenterId   String?
  projectId      String?
  description    String?

  debit  Decimal @db.Decimal(20, 4)
  credit Decimal @db.Decimal(20, 4)

  currencyId           String?
  foreignDebit         Decimal? @db.Decimal(20, 4)
  foreignCredit        Decimal? @db.Decimal(20, 4)
  exchangeRateSnapshot Decimal? @db.Decimal(20, 6)

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
  costCenter   CostCenter?  @relation(fields: [costCenterId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])
  currency     Currency?    @relation(fields: [currencyId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

model Attachment {
  id             String   @id @default(cuid())
  organizationId String
  fileName       String
  mimeType       String
  size           Int
  path           String
  createdAt      DateTime @default(now())

  organization       Organization        @relation(fields: [organizationId], references: [id])
  journalAttachments JournalAttachment[]
  invoiceAttachments InvoiceAttachment[]
}

model JournalAttachment {
  journalEntryId String
  attachmentId   String

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  attachment   Attachment   @relation(fields: [attachmentId], references: [id])

  @@id([journalEntryId, attachmentId])
}

model InvoiceAttachment {
  id           String @id @default(cuid())
  attachmentId String
  entityType   String
  entityId     String

  attachment Attachment @relation(fields: [attachmentId], references: [id])

  @@index([entityType, entityId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model JournalApproval {
  id             String         @id @default(cuid())
  journalEntryId String
  approverId     String
  status         ApprovalStatus @default(PENDING)
  comment        String?
  approvedAt     DateTime?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  approver     User         @relation(fields: [approverId], references: [id])
}

enum SystemAccountKey {
  CASH
  PETTY_CASH

  BANK

  ACCOUNTS_RECEIVABLE
  ACCOUNTS_PAYABLE

  SALES
  SALES_RETURN

  PURCHASE
  PURCHASE_RETURN

  INVENTORY
  TAX_PAYABLE
  TAX_RECEIVABLE

  DISCOUNT_GIVEN
  DISCOUNT_RECEIVED

  EXCHANGE_GAIN
  EXCHANGE_LOSS

  RETAINED_EARNINGS
}

model SystemAccount {
  id String @id @default(cuid())

  organizationId String

  key  SystemAccountKey
  name String

  accountId String

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@unique([organizationId, key])
}

model FiscalYearClosing {
  id               String   @id @default(cuid())
  organizationId   String
  fiscalYearId     String
  closedById       String?
  closedAt         DateTime
  retainedEarnings Decimal  @db.Decimal(20, 4)
  notes            String?

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id])
  closedBy   User?      @relation(fields: [closedById], references: [id])

  @@unique([fiscalYearId])
}

enum JournalTemplateType {
  SALES
  PURCHASE
  CASH_RECEIPT
  CASH_PAYMENT
  BANK_DEPOSIT
  BANK_WITHDRAW
  PAYROLL
  GENERAL
}

model JournalTemplate {
  id             String              @id @default(cuid())
  organizationId String
  name           String
  type           JournalTemplateType
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())

  organization      Organization          @relation(fields: [organizationId], references: [id])
  lines             JournalTemplateLine[]
  // NEW
  recurringJournals RecurringJournal[]
}

enum TemplateAmountType {
  FIXED
  PERCENT
  DYNAMIC
}

model JournalTemplateLine {
  id          String             @id @default(cuid())
  templateId  String
  accountId   String
  isDebit     Boolean
  amountType  TemplateAmountType
  amount      Decimal?           @db.Decimal(20, 4)
  description String?
  sortOrder   Int                @default(0)

  template JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  account  Account         @relation(fields: [accountId], references: [id])
}

// ================================================================
// RECURRING JOURNAL — سند حسابداری تکرارشونده (NEW)
// ================================================================

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringJournal {
  id             String             @id @default(cuid())
  organizationId String
  templateId     String
  name           String
  frequency      RecurringFrequency
  startDate      DateTime
  endDate        DateTime?
  nextRunDate    DateTime
  lastRunDate    DateTime?
  isActive       Boolean            @default(true)
  amount         Decimal?           @db.Decimal(20, 4)
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization    @relation(fields: [organizationId], references: [id])
  template         JournalTemplate @relation(fields: [templateId], references: [id])
  generatedEntries JournalEntry[]  @relation("RecurringSource")

  @@index([organizationId, nextRunDate])
}

// ================================================================
// COST ALLOCATION — FIX: بازطراحی Polymorphic Relation
// ================================================================

enum AllocationSourceType {
  JOURNAL_ENTRY
  PURCHASE_INVOICE
  SALES_INVOICE
  PAYROLL
}

// FIX: به جای یک targetId چندوجهی، costCenterId و projectId جداگانه
model Allocation {
  id             String               @id @default(cuid())
  organizationId String
  sourceType     AllocationSourceType
  sourceId       String
  costCenterId   String?
  projectId      String?
  amount         Decimal              @db.Decimal(20, 4)
  percentage     Decimal?             @db.Decimal(5, 2) // NEW: درصد تخصیص
  allocationDate DateTime
  createdAt      DateTime             @default(now())

  costCenter CostCenter? @relation(fields: [costCenterId], references: [id])
  project    Project?    @relation(fields: [projectId], references: [id])

  @@index([sourceType, sourceId])
  @@index([costCenterId])
  @@index([projectId])
}

// NEW: قوانین تخصیص خودکار هزینه
model AllocationRule {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  sourceAccountId String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  items AllocationRuleItem[]
}

model AllocationRuleItem {
  id           String  @id @default(cuid())
  ruleId       String
  costCenterId String?
  projectId    String?
  percentage   Decimal @db.Decimal(5, 2)

  rule AllocationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

// ================================================================
// TAX ENGINE
// ================================================================

enum TaxType {
  VAT
  WITHHOLDING
  EXCISE
  CUSTOMS
}

model TaxRate {
  id             String  @id @default(cuid())
  organizationId String
  code           String
  name           String
  type           TaxType
  rate           Decimal @db.Decimal(10, 4)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  groupItems      TaxGroupItem[]
  invoiceTaxLines InvoiceTaxLine[]

  @@unique([organizationId, code])
}

model TaxGroup {
  id             String @id @default(cuid())
  organizationId String
  code           String
  name           String

  organization Organization   @relation(fields: [organizationId], references: [id])
  items        TaxGroupItem[]

  @@unique([organizationId, code])
}

model TaxGroupItem {
  id         String @id @default(cuid())
  taxGroupId String
  taxRateId  String

  taxGroup TaxGroup @relation(fields: [taxGroupId], references: [id], onDelete: Cascade)
  taxRate  TaxRate  @relation(fields: [taxRateId], references: [id])

  @@unique([taxGroupId, taxRateId])
}

model InvoiceTaxLine {
  id            String  @id @default(cuid())
  taxRateId     String
  entityType    String
  entityId      String
  taxableAmount Decimal @db.Decimal(20, 4)
  taxAmount     Decimal @db.Decimal(20, 4)

  taxRate TaxRate @relation(fields: [taxRateId], references: [id])

  @@index([entityType, entityId])
  @@index([taxRateId])
}

// ================================================================
// PARTY — Customer, Supplier, Employee (master)
// ================================================================

enum PartyType {
  CUSTOMER
  SUPPLIER
  EMPLOYEE
  SHAREHOLDER
  BOTH
  OTHER
}

model Party {
  id             String    @id @default(cuid())
  organizationId String
  code           String
  type           PartyType
  isCompany      Boolean

  firstName       String?
  lastName        String?
  companyName     String?
  nationalId      String?
  economicCode    String?
  phone           String?
  mobile          String?
  email           String?
  notes           String?  @db.Text
  creditLimit     Decimal? @db.Decimal(20, 4)
  paymentTermDays Int?

  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  addresses           PartyAddress[]
  contacts            PartyContact[]
  bankAccounts        PartyBankAccount[]
  purchaseOrders      PurchaseOrder[]
  purchaseInvoices    PurchaseInvoice[]
  cashTransactions    CashTransaction[]
  bankTransactions    BankTransaction[]
  checks              Check[]
  salesQuotations     SalesQuotation[]
  salesOrders         SalesOrder[]
  salesInvoices       SalesInvoice[]
  partyLedger         PartyLedger[]
  payments            Payment[]
  employee            Employee?
  customerCreditNotes SalesCreditNote[]   @relation("CustomerCreditNotes")
  supplierDebitNotes  PurchaseDebitNote[] @relation("SupplierDebitNotes")
  // NEW
  purchaseRequests    PurchaseRequest[]
  contracts           Contract[]

  @@unique([organizationId, code])
}

model PartyBankAccount {
  id            String  @id @default(cuid())
  partyId       String
  bankId        String
  accountNumber String
  iban          String?
  cardNumber    String?
  accountHolder String?
  branchName    String?
  isDefault     Boolean @default(false)

  party     Party    @relation(fields: [partyId], references: [id])
  bank      Bank     @relation(fields: [bankId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyId])
}

model PartyAddress {
  id         String  @id @default(cuid())
  partyId    String
  title      String
  address    String  @db.Text
  postalCode String?
  city       String?
  country    String?
  isDefault  Boolean @default(false)

  party Party @relation(fields: [partyId], references: [id])
}

model PartyContact {
  id       String  @id @default(cuid())
  partyId  String
  fullName String
  position String?
  mobile   String?
  phone    String?
  email    String?

  party Party @relation(fields: [partyId], references: [id])
}

enum PartyLedgerType {
  INVOICE
  PAYMENT
  CREDIT_NOTE
  DEBIT_NOTE
  OPENING_BALANCE
}

model PartyLedger {
  id              String          @id @default(cuid())
  organizationId  String
  partyId         String
  transactionDate DateTime
  type            PartyLedgerType
  debit           Decimal         @db.Decimal(20, 4)
  credit          Decimal         @db.Decimal(20, 4)
  referenceType   String?
  referenceId     String?
  description     String?
  createdAt       DateTime        @default(now())

  party Party @relation(fields: [partyId], references: [id])

  @@index([partyId])
  @@index([organizationId, transactionDate])
}

// ================================================================
// TREASURY
// ================================================================

model CashBox {
  id             String    @id @default(cuid())
  organizationId String
  code           String
  name           String
  accountId      String
  isActive       Boolean   @default(true)
  // FIX: اضافه شد
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization  Organization      @relation(fields: [organizationId], references: [id])
  account       Account           @relation(fields: [accountId], references: [id])
  transactions  CashTransaction[]
  transfersFrom Transfer[]        @relation("TransferFromCash")
  transfersTo   Transfer[]        @relation("TransferToCash")

  @@unique([organizationId, code])
}

enum CashTransactionType {
  RECEIPT
  PAYMENT
}

model CashTransaction {
  id              String              @id @default(cuid())
  cashBoxId       String
