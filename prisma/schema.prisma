model BillOfMaterials {
  id             String  @id @default(cuid())
  organizationId String
  code           String
  name           String
  finishedGoodId String
  quantity       Decimal @db.Decimal(20, 4)
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  finishedGood     Product           @relation(fields: [finishedGoodId], references: [id])
  components       BomComponent[]
  productionOrders ProductionOrder[]

  @@unique([organizationId, code])
}

model BomComponent {
  id        String  @id @default(cuid())
  bomId     String
  productId String
  quantity  Decimal @db.Decimal(20, 4)
  unitId    String?
  notes     String?

  bom     BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
}

enum ProductionOrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionOrder {
  id             String                @id @default(cuid())
  organizationId String
  orderNumber    String
  bomId          String
  warehouseId    String
  status         ProductionOrderStatus @default(DRAFT)
  plannedQty     Decimal               @db.Decimal(20, 4)
  producedQty    Decimal               @default(0) @db.Decimal(20, 4)
  plannedStart   DateTime?
  plannedEnd     DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization            @relation(fields: [organizationId], references: [id])
  bom          BillOfMaterials         @relation(fields: [bomId], references: [id])
  consumptions ProductionConsumption[]
  outputs      ProductionOutput[]

  @@unique([organizationId, orderNumber])
}

model ProductionConsumption {
  id                String   @id @default(cuid())
  productionOrderId String
  productId         String
  warehouseId       String
  plannedQty        Decimal  @db.Decimal(20, 4)
  actualQty         Decimal  @default(0) @db.Decimal(20, 4)
  unitCost          Decimal? @db.Decimal(20, 4)
  createdAt         DateTime @default(now())

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
}

model ProductionOutput {
  id                String   @id @default(cuid())
  productionOrderId String
  productId         String
  warehouseId       String
  quantity          Decimal  @db.Decimal(20, 4)
  unitCost          Decimal? @db.Decimal(20, 4)
  isScrap           Boolean  @default(false)
  createdAt         DateTime @default(now())

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
}

