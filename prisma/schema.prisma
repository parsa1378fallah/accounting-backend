  PART_TIME
  CONTRACT
  INTERN
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

model Employee {
  id              String           @id @default(cuid())
  organizationId  String
  partyId         String           @unique
  employeeCode    String
  departmentId    String?
  positionId      String?
