model Transfer {
  id                String   @id @default(cuid())
  organizationId    String
  transferDate      DateTime
  amount            Decimal  @db.Decimal(20, 4)
  description       String?
  journalEntryId    String?
  fromCashBoxId     String?
  fromBankAccountId String?
  toCashBoxId       String?
  toBankAccountId   String?

  organization    Organization  @relation(fields: [organizationId], references: [id])
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])
  fromCashBox     CashBox?      @relation("TransferFromCash", fields: [fromCashBoxId], references: [id])
  toCashBox       CashBox?      @relation("TransferToCash", fields: [toCashBoxId], references: [id])
  fromBankAccount BankAccount?  @relation("TransferFromBank", fields: [fromBankAccountId], references: [id])
  toBankAccount   BankAccount?  @relation("TransferToBank", fields: [toBankAccountId], references: [id])
