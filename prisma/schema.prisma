model PayrollItemLine {
  id            String  @id @default(cuid())
  payrollItemId String
  componentId   String
  amount        Decimal @db.Decimal(20, 4)

  payrollItem PayrollItem     @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
