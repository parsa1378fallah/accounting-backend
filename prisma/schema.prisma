model Unit {
  id             String   @id @default(cuid())
  organizationId String
  code           String
  name           String
  symbol         String
  createdAt      DateTime @default(now())

  products Product[]

  @@unique([organizationId, code])
}

model Brand {
  id             String @id @default(cuid())
  organizationId String
  code           String
  name           String

  products Product[]

  @@unique([organizationId, code])
}

enum ProductType {
  PRODUCT
  SERVICE
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOOD
}

model Product {
  id             String      @id @default(cuid())
  organizationId String
  code           String
  sku            String?
  barcode        String?
  name           String
  categoryId     String
  unitId         String
  brandId        String?
  type           ProductType
  taxGroupId     String?
  purchasePrice  Decimal?    @db.Decimal(20, 4)
  salePrice      Decimal?    @db.Decimal(20, 4)
  minStockLevel  Decimal?    @db.Decimal(20, 4)
  maxStockLevel  Decimal?    @db.Decimal(20, 4)
  trackInventory Boolean     @default(true)
  trackLot       Boolean     @default(false)
  trackSerial    Boolean     @default(false)
  description    String?
  isActive       Boolean     @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization          Organization             @relation(fields: [organizationId], references: [id])
  category              ProductCategory          @relation(fields: [categoryId], references: [id])
  unit                  Unit                     @relation(fields: [unitId], references: [id])
  brand                 Brand?                   @relation(fields: [brandId], references: [id])
  variants              ProductVariant[]
  inventoryTransactions InventoryTransaction[]
  inventoryLots         InventoryLot[]
  inventorySerials      InventorySerial[]
  balances              InventoryBalance[]
  reservations          InventoryReservation[]
  adjustmentLogs        InventoryAdjustmentLog[]
  purchaseInvoiceItems  PurchaseInvoiceItem[]
  purchaseOrderItems    PurchaseOrderItem[]
  salesQuotationItems   SalesQuotationItem[]
  salesOrderItems       SalesOrderItem[]
  salesInvoiceItems     SalesInvoiceItem[]
  bomComponents         BomComponent[]
  bomFinishedGoods      BillOfMaterials[]
  salesReturnItems      SalesReturnItem[]
  purchaseReturnItems   PurchaseReturnItem[]
  // NEW
  stockTransferItems    StockTransferItem[]
  purchaseRequestItems  PurchaseRequestItem[]
  priceListItems        PriceListItem[]
  contractItems         ContractItem[]

  @@unique([organizationId, code])
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  code            String
  name            String
  additionalPrice Decimal? @db.Decimal(20, 4)

  product        Product         @relation(fields: [productId], references: [id])
  priceListItems PriceListItem[]
}

model Warehouse {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String
  code           String
  name           String
  description    String?
  isActive       Boolean   @default(true)
  // FIX: اضافه شد
  deletedAt      DateTime?

  organization       Organization             @relation(fields: [organizationId], references: [id])
  branch             Branch                   @relation(fields: [branchId], references: [id])
  transactions       InventoryTransaction[]
  balances           InventoryBalance[]
  reservations       InventoryReservation[]
  adjustmentLogs     InventoryAdjustmentLog[]
  // NEW
  stockTransfersFrom StockTransfer[]          @relation("StockTransferFrom")
  stockTransfersTo   StockTransfer[]          @relation("StockTransferTo")

  @@unique([organizationId, code])
}

enum InventoryTransactionType {
  PURCHASE
  SALE
  PURCHASE_RETURN
  SALE_RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  PRODUCTION_IN
  PRODUCTION_OUT
}

model InventoryTransaction {
  id              String                   @id @default(cuid())
  organizationId  String
  productId       String
  warehouseId     String
  variantId       String?
  lotId           String?
  serialId        String?
  transactionDate DateTime
  type            InventoryTransactionType
  quantity        Decimal                  @db.Decimal(20, 4)
  unitCost        Decimal?                 @db.Decimal(20, 4)
  totalCost       Decimal?                 @db.Decimal(20, 4)
  referenceType   String?
  referenceId     String?
  createdAt       DateTime                 @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([productId, warehouseId])
  @@index([transactionDate])
  @@index([referenceType, referenceId])
}

model InventoryBalance {
  id             String   @id @default(cuid())
  organizationId String
  productId      String
  warehouseId    String
  quantity       Decimal  @db.Decimal(20, 4)
  reservedQty    Decimal  @default(0) @db.Decimal(20, 4)
  averageCost    Decimal? @db.Decimal(20, 4)
  lastCost       Decimal? @db.Decimal(20, 4)
  updatedAt      DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([warehouseId])
  @@index([organizationId])
}

model InventoryReservation {
  id             String    @id @default(cuid())
  organizationId String
  productId      String
  warehouseId    String
  quantity       Decimal   @db.Decimal(20, 4)
  referenceType  String
  referenceId    String
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([productId, warehouseId])
  @@index([referenceType, referenceId])
}

model InventoryAdjustmentLog {
  id             String   @id @default(cuid())
  organizationId String
  productId      String
  warehouseId    String
  changeQty      Decimal  @db.Decimal(20, 4)
  reason         String
  referenceType  String?
  referenceId    String?
  createdAt      DateTime @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([productId, warehouseId])
  @@index([organizationId, createdAt])
}

model InventoryLot {
  id              String    @id @default(cuid())
  productId       String
  lotNumber       String
  manufactureDate DateTime?
  expiryDate      DateTime?
  createdAt       DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, lotNumber])
}

model InventorySerial {
  id           String @id @default(cuid())
  productId    String
  serialNumber String @unique

  product Product @relation(fields: [productId], references: [id])
}

