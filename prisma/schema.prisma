  employees Employee[]

  @@unique([organizationId, code])
}

model Position {
  id             String @id @default(cuid())
  organizationId String
  code           String
  name           String
  gradeLevel     Int?

  employees Employee[]

  @@unique([organizationId, code])
}

enum SalaryComponentType {
  EARNING
  DEDUCTION
}

model SalaryComponent {
  id          String              @id @default(cuid())
  code        String              @unique
  name        String
  type        SalaryComponentType
