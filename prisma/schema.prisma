// ================================================================

enum WorkflowEntityType {
  JOURNAL_ENTRY
  PURCHASE_ORDER
  PURCHASE_REQUEST
  PURCHASE_INVOICE
  SALES_ORDER
  SALES_INVOICE
  PAYMENT
  PAYROLL_RUN
  LEAVE_REQUEST
}

enum WorkflowStepAction {
  APPROVE
  REJECT
  FORWARD
}

model WorkflowDefinition {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  entityType     WorkflowEntityType
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  steps        WorkflowStep[]
  instances    WorkflowInstance[]

  @@unique([organizationId, entityType, name])
}

model WorkflowStep {
  id           String  @id @default(cuid())
  definitionId String
  stepOrder    Int
  name         String
  approverId   String? // اگر null باشد dynamic تعیین می‌شود

  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  actions    WorkflowAction[]

  @@unique([definitionId, stepOrder])
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

model WorkflowInstance {
  id             String             @id @default(cuid())
  organizationId String
  definitionId   String
  entityType     WorkflowEntityType
  entityId       String
  currentStep    Int                @default(1)
  status         WorkflowStatus     @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id])
  actions      WorkflowAction[]

  @@index([entityType, entityId])
  @@index([organizationId, status])
}

model WorkflowAction {
  id         String             @id @default(cuid())
  instanceId String
  stepId     String
  actorId    String
  action     WorkflowStepAction
  comment    String?
  actedAt    DateTime           @default(now())

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step     WorkflowStep     @relation(fields: [stepId], references: [id])
  actor    User             @relation(fields: [actorId], references: [id])

  @@index([instanceId])
}

